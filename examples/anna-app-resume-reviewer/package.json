{
  "name": "anna-app-resume-reviewer",
  "private": true,
  "version": "0.1.0",
  "description": "Anna App for AI-assisted resume review with ATS scoring, reviewer perspectives, approved changes, and version history.",
  "type": "module",
  "scripts": {
    "dev": "anna-app dev --port 5184 --llm-account https://anna.partners",
    "dev:off": "anna-app dev --port 5184 --no-llm",
    "validate": "anna-app validate --strict",
    "fixture:verify": "anna-app fixture verify fixtures/happy-path.jsonl",
    "test": "vitest run && python -m py_compile executas/resume-reviewer-python/resume_reviewer_plugin.py"
  },
  "devDependencies": {
    "@anna-ai/cli": "^0.1.22",
    "playwright": "^1.61.0",
    "vitest": "^4.1.9"
  }
}
