{
  "schema": 2,
  "permissions": [
    "storage.read",
    "storage.write",
    "chat.write_message",
    "chat.append_artifact",
    "ui.svg"
  ],
  "required_executas": [],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the AI Resume Reviewer Anna App open. The app performs inline resume analysis in the browser, including ATS score, missing keywords, prioritized issues, suggested changes, and an editable improved draft. Prefer structured, actionable feedback over generic resume advice.",
  "user_message_prefix_template": "[AI Resume Reviewer] {user_message}",
  "tags": ["resume", "career", "ats", "job-search", "students"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "AI Resume Reviewer",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 320, "h": 620 },
        "default_size": { "w": 1180, "h": 820 },
        "max_size": { "w": 1440, "h": 960 },
        "resizable": true,
        "movable": true,
        "single_instance": true,
        "icon": "icon.svg"
      }
    ],
    "host_api": {
      "storage": ["get", "set", "delete", "list"],
      "chat": ["write_message", "append_artifact"],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "img-src": ["'self'", "data:", "blob:"],
      "font-src": ["'self'", "data:"],
      "style-src": ["'self'"],
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
